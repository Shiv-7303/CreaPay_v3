+    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
     <script>
+        // Razorpay Checkout Integration
+        const rzpBtn = document.getElementById('rzp-button');
+        if (rzpBtn) {
+            rzpBtn.onclick = async function(e){
+                e.preventDefault();
+                rzpBtn.innerText = "Processing...";
+                rzpBtn.disabled = true;
+                
+                try {
+                    // 1. Create order on backend
+                    const response = await fetch('/payments/create-order', { method: 'POST' });
+                    const orderData = await response.json();
+                    
+                    if (response.ok) {
+                        // 2. Initialize Razorpay
+                        var options = {
+                            "key": orderData.key_id, // In production this would be rendered from config
+                            "amount": orderData.amount,
+                            "currency": orderData.currency,
+                            "name": "CreaPay Pro",
+                            "description": "Upgrade to Pro Plan",
+                            "order_id": orderData.id,
+                            "handler": function (response) {
+                                // On success, the backend webhook will upgrade the user.
+                                // We can just reload the page to see the new Pro status.
+                                alert("Payment Successful! Welcome to Pro.");
+                                window.location.reload();
+                            },
+                            "prefill": {
+                                "name": "{{ current_user.full_name }}",
+                                "email": "{{ current_user.email }}"
+                            },
+                            "theme": {
+                                "color": "#6C47FF"
+                            }
+                        };
+                        var rzp1 = new Razorpay(options);
+                        rzp1.on('payment.failed', function (response){
+                            alert("Payment Failed. Reason: " + response.error.description);
+                        });
+                        rzp1.open();
+                    } else {
+                        alert("Error initiating payment: " + (orderData.error || "Unknown error"));
+                    }
+                } catch (err) {
+                    alert("Network error: Could not reach payment server.");
+                } finally {
+                    rzpBtn.innerText = "Upgrade to Pro Now";
+                    rzpBtn.disabled = false;
+                }
+            }
+        }
